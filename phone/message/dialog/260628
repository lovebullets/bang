<style>
@keyframes iMsg { 0% { opacity: 0; transform: translateY(10px) scale(0.98); } 100% { opacity: 1; transform: translateY(0) scale(1); } }
@keyframes fade { 0% { opacity: 0; } 100% { opacity: 1; } }
@keyframes popIn { 0% { transform: scale(0.9); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
#preview-box, #preview-box * { font-family: -apple-system, BlinkMacSystemFont, sans-serif !important; }
.msg-bubble { opacity: 0; animation: iMsg 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards; }
.read-status { opacity: 0; animation: fade 1s ease forwards; }
.msg-date-delayed { opacity: 0; animation: fade 0.01s forwards; }
.msg-bubble > div { word-break: break-word; }
.lb-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: transparent; z-index: 99999; justify-content: center; align-items: center; cursor: pointer; }
.lb-img { max-width: 90%; max-height: 85vh; object-fit: contain; border-radius: 12px; box-shadow: 0 20px 50px rgba(0,0,0,0.5); cursor: default; animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
.lb-close { position: absolute; bottom: 30px; background: rgba(0,0,0,0.6); color: white; padding: 8px 20px; border-radius: 20px; font-size: 13px; font-weight: 600; backdrop-filter: blur(4px); pointer-events: none; }
</style>
